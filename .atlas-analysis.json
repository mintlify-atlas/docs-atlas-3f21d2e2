  "keyFeatures": [
    "Modular Monolith Architecture with Vertical Slices",
    "CQRS with Mediator Pattern and FluentValidation",
    "Multi-Tenancy with Finbuckle (Database-per-Tenant)",
    "Complete Identity & Authorization (ASP.NET Identity + JWT)",
    "Built-in Modules: Identity, Multitenancy, Auditing",
    "EF Core 10 with Specifications Pattern",
    "Distributed Caching with Redis",
    "Background Jobs with Hangfire",
    "OpenTelemetry Observability (Traces, Metrics, Logs)",
    "API Versioning and Rate Limiting",
    "OpenAPI/Swagger Documentation with Scalar UI",
    "Aspire AppHost for Local Development",
    "Terraform Infrastructure as Code"
  ],
  "publicApiSurface": [
    "AddHeroPlatform() - Register framework services",
    "UseHeroPlatform() - Configure middleware pipeline",
    "AddModules() - Register custom modules",
    "MapModules() - Map module endpoints",
    "AddHeroDbContext<T>() - Register tenant-aware DbContext",
    "UseHeroMultiTenantDatabases() - Apply tenant migrations",
    "ICommand<T> / IQuery<T> - CQRS command/query contracts",
    "ICommandHandler<TCommand, TResult> - Command handler interface",
    "IQueryHandler<TQuery, TResult> - Query handler interface",
    "IModule - Module registration interface",
    "IRepository<T> - Repository pattern interface",
    "IReadRepository<T> - Read-only repository interface",
    "ISpecification<T> - Specification pattern interface",
    "RequirePermission() - Permission-based authorization",
    "/api/v1/identity/tokens - JWT token generation",
    "/api/v1/identity/tokens/refresh - Token refresh",
    "/api/v1/identity/users - User management",
    "/api/v1/identity/roles - Role management",
    "/api/v1/multitenancy/tenants - Tenant management",
    "/api/v1/auditing/security - Security audit logs"
  ]
